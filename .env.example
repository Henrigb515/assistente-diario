# ==== LLM ====
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_COPY=claude-opus-4-7

# ==== Google Drive ====
# Caminho absoluto para o JSON da Service Account
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json
# ID da pasta do Drive onde os carrosseis serao salvos
GOOGLE_DRIVE_FOLDER_ID=

# ==== Fontes de noticias ====
# Lista separada por virgula de URLs a serem raspadas
NEWS_URLS=https://www.heinekenbrasil.com.br,https://www.theheinekencompany.com/newsroom,https://exame.com/negocios,https://valor.globo.com/empresas,https://www.cnnbrasil.com.br/economia,https://www.brejas.com.br,https://www.cervesia.com.br,https://www.beerart.com.br,https://www.afabbra.org.br,https://www.aditivosingredientes.com,https://www.monitormercantil.com.br

# Google News RSS queries (separadas por |)
GOOGLE_NEWS_QUERIES=Heineken Brasil|Grupo Heineken|Amstel cerveja|Eisenbahn|mercado cervejeiro Brasil|imposto seletivo bebidas

# Perfis Instagram a monitorar (sem @, separados por virgula)
IG_PROFILES=novanortedistribuidora,fys_oficial,grupoheinekenbr,amstelbr,cervejapraya,cervejaglacial,cervejabadenbaden,heineken,tigerbeerbr,itubaina,bluemoon.br,heinekenbr,eisenbahn

# ==== Pipeline ====
TZ=America/Sao_Paulo
OUTPUT_DIR=./backend/output
LOG_LEVEL=INFO
